# Docker Compose environment variables
# Copy this file to .env and fill in your actual values.
# This file is committed — do NOT put real credentials here.

POSTGRES_DB=workout_plan_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

MESSENGER_TRANSPORT_DSN=amqp://guest:guest@rabbitmq:5672/%2f/messages

# Mailtrap sandbox — get credentials from https://mailtrap.io → Email Testing → SMTP Settings
MAILER_DSN=smtp://YOUR_MAILTRAP_USER:YOUR_MAILTRAP_PASSWORD@sandbox.smtp.mailtrap.io:2525
